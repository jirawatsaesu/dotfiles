[user]
	name = Jirawat Yuktawathin

[core]
	ignoreCase = false
	excludesFile = ~/.gitignore_global

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[init]
	defaultBranch = main

[includeIf "gitdir:~/personal/"]
	path = ~/.gitconfig-personal

[includeIf "gitdir:D:/personal/"]
	path = ~/.gitconfig-personal

[includeIf "gitdir:~/coraline/"]
	path = ~/.gitconfig-coraline

[includeIf "gitdir:D:/coraline/"]
	path = ~/.gitconfig-coraline
