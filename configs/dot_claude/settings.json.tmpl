{
  "env": {
    "FIGMA_TOKEN": "YOUR_FIGMA_TOKEN_HERE"
  },
  "statusLine": {
    "type": "command",
    "command": "{{ if eq .chezmoi.os "windows" }}powershell -NoProfile -File ~/.claude/statusline-command.ps1{{ else }}bash ~/.claude/statusline-command.sh{{ end }}"
  },
  "enabledPlugins": {
    "andrej-karpathy-skills@karpathy-skills": true
  },
  "extraKnownMarketplaces": {
    "karpathy-skills": {
      "source": {
        "source": "github",
        "repo": "forrestchang/andrej-karpathy-skills"
      }
    }
  },
  "effortLevel": "high",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "theme": "dark",
  "voiceEnabled": true
}
